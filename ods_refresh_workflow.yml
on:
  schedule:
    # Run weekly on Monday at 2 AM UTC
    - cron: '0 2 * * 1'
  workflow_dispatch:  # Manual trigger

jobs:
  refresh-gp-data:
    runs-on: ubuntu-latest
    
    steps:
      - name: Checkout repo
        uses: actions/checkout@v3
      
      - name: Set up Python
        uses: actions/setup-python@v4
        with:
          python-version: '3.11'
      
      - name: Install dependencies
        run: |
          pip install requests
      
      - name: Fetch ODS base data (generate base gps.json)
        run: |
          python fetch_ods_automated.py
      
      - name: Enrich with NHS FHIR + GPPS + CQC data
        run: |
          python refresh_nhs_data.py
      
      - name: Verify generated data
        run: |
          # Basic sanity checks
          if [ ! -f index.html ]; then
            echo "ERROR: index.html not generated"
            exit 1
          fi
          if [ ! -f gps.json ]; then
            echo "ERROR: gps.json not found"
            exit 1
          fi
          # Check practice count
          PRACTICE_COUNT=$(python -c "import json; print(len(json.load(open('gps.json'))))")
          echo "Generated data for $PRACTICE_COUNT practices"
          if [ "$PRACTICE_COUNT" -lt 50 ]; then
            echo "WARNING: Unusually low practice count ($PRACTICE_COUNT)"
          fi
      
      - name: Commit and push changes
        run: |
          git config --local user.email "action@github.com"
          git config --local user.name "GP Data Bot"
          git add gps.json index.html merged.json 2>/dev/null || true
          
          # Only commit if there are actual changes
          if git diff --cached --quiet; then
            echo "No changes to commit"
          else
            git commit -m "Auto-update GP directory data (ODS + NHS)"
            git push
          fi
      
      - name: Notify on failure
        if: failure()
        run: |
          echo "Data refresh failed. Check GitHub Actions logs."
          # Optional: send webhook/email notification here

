name: Automated ODS + NHS Data Refresh

on:
  schedule:
    # Run weekly on Monday at 2 AM UTC
    - cron: '0 2 * * 1'
  workflow_dispatch:  # Manual trigger

jobs:
  refresh-gp-data:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout repo
        uses: actions/checkout@v3
      
      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'
      
      - name: Install dependencies
        run: |
          pip install requests
      
      - name: Fetch ODS base data (generate base gps.json)
        run: |
          python fetch_ods_automated.py
      
      - name: Enrich with NHS FHIR + GPPS + CQC data
        run: |
          python refresh_nhs_data.py
      
      - name: Verify generated data
        run: |
          # Basic sanity checks
          if [ ! -f index.html ]; then
            echo "ERROR: index.html not generated"
            exit 1
          fi
          if [ ! -f gps.json ]; then
            echo "ERROR: gps.json not found"
            exit 1
          fi
          # Check practice count
          PRACTICE_COUNT=$(python -c "import json; print(len(json.load(open('gps.json'))))")
          echo "Generated data for $PRACTICE_COUNT practices"
          if [ "$PRACTICE_COUNT" -lt 50 ]; then
            echo "WARNING: Unusually low practice count ($PRACTICE_COUNT)"
          fi
      
      - name: Commit and push changes
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GP Data Bot"
          git add gps.json index.html merged.json 2>/dev/null || true
          
          # Only commit if there are actual changes
          if git diff --cached --quiet; then
            echo "No changes to commit"
          else
            git commit -m "Auto-update GP directory data (ODS + NHS)"
            git push
          fi
      
      - name: Notify on failure
        if: failure()
        run: |
          echo "Data refresh failed. Check GitHub Actions logs."
          # Optional: send webhook/email notification here

